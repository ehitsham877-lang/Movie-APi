APP_NAME="Movie API"

# Optional: simple API-key auth for all `/v1/*` routes.
# Send it as the `X-API-Key` header.
API_KEY=

# Comma-separated providers to enable. If none are valid, the app falls back to `mock`.
PROVIDERS=mock,tmdb

# TMDb (https://www.themoviedb.org/) - required to enable the `tmdb` provider.
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
